# ./ns3 run "scratch/project/simulation --standard=ax --nUsers=1 --trafficType=extra --packetSize=1500 --msduLength=11398 --enableAmpdu=1 --enableAmsdu=1 --ampduMpdus=256000 --runName=ax_ampdu256_msdu512"
# ./ns3 run "scratch/project/simulation --standard=ac --nUsers=1 --trafficType=extra --packetSize=1500 --msduLength=11398 --enableAmpdu=1 --enableAmsdu=1 --ampduMpdus=64000 --runName=ac_ampdu64_msdu512"


echo "Generating plots..."
# python3 plot.py


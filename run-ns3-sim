#!/bin/bash
set -e

mkdir -p results
mkdir -p results/throughput_time
mkdir -p plots

rm -f results/summary.csv
rm -f results/per_flow.csv
rm -f results/throughput_time/*.csv

echo "Running ns-3 simulations..."

# Changing number of clients
./ns3 run "scratch/project/simulation --standard=ax --nUsers=1 --runName=ax_user1"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=1 --runName=ac_user1"

./ns3 run "scratch/project/simulation --standard=ax --nUsers=2 --runName=ax_user2"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=2 --runName=ac_user2"

./ns3 run "scratch/project/simulation --standard=ax --nUsers=4 --runName=ax_user4"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=4 --runName=ac_user4"

./ns3 run "scratch/project/simulation --standard=ax --nUsers=8 --runName=ax_user8"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=8 --runName=ac_user8"

./ns3 run "scratch/project/simulation --standard=ax --nUsers=16 --runName=ax_user16"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=16 --runName=ac_user16"

./ns3 run "scratch/project/simulation --standard=ax --nUsers=32 --runName=ax_user32"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=32 --runName=ac_user32"

./ns3 run "scratch/project/simulation --standard=ax --nUsers=64 --runName=ax_user64"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=64 --runName=ac_user64"

./ns3 run "scratch/project/simulation --standard=ax --nUsers=128 --runName=ax_user128"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=128 --runName=ac_user128"

# Single user, many small packets test
./ns3 run "scratch/project/simulation --standard=ax --nUsers=16 --packetSize=128 --runName=ax_pkt128"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=16 --packetSize=128 --runName=ac_pkt128"

./ns3 run "scratch/project/simulation --standard=ax --nUsers=16 --packetSize=1500 --runName=ax_pkt1500"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=16 --packetSize=1500 --runName=ac_pkt1500"

# SNR tests 
./ns3 run "scratch/project/simulation --standard=ax --nUsers=16 --movementType=Static1m --addPropagation=1 --runName=ax_high_density_environment_1m_from_AP"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=16 --movementType=Static1m --addPropagation=1 --runName=ac_high_density_environment_1m_from_AP"

./ns3 run "scratch/project/simulation --standard=ax --nUsers=16 --movementType=Static10m --addPropagation=1 --runName=ax_high_density_environment_10m_from_AP"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=16 --movementType=Static10m --addPropagation=1 --runName=ac_high_density_environment_10m_from_AP"

./ns3 run "scratch/project/simulation --standard=ax --nUsers=16 --movementType=Static30m --addPropagation=1 --runName=ax_high_density_environment_30m_from_AP"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=16 --movementType=Static30m --addPropagation=1 --runName=ac_high_density_environment_30m_from_AP"

./ns3 run "scratch/project/simulation --standard=ax --nUsers=16 --movementType=StaticRandom_1m-30m --addPropagation=1 --runName=ax_high_density_environment_1m-30m_from_AP"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=16 --movementType=StaticRandom_1m-30m --addPropagation=1 --runName=ac_high_density_environment_1m-30m_from_AP"

# High density environment 
./ns3 run "scratch/project/simulation --standard=ax --nUsers=16 --trafficType=medium --movementType=moving --addPropagation=1 --runName=ax_dynamic"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=16 --trafficType=medium --movementType=moving --addPropagation=1 --runName=ac_dynamic"

./ns3 run "scratch/project/simulation --standard=ax --nUsers=16 --trafficType=medium --movementType=Static10m --addPropagation=1 --runName=ax_static"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=16 --trafficType=medium --movementType=Static10m --addPropagation=1 --runName=ac_static"

# Single user, aggregation tests 

# msdu = 7935 bytes
./ns3 run "scratch/project/simulation --standard=ax --nUsers=1 --trafficType=extra --packetSize=1500 --msduLength=7935 --enableAmpdu=1 --enableAmsdu=1 --ampduMpdus=64000 --runName=ax_ampdu64_msdu"
./ns3 run "scratch/project/simulation --standard=ax --nUsers=1 --trafficType=extra --packetSize=1500 --msduLength=7935 --enableAmpdu=1 --enableAmsdu=1 --ampduMpdus=256000 --runName=ax_ampdu256_msdu"
./ns3 run "scratch/project/simulation --standard=ac --nUsers=1 --trafficType=extra --packetSize=1500 --msduLength=7935 --enableAmpdu=1 --enableAmsdu=1 --ampduMpdus=64000 --runName=ac_ampdu64_msdu"

